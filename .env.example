# HisabVani Environment Variables
# Copy this file to .env and fill in your keys

# Sarvam AI API (get from https://dashboard.sarvam.ai/)
SARVAM_API_KEY=

# Daytona Sandbox (get from https://app.daytona.io/)
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api

# HeyGen audio catalog (music + sound effects)
HEYGEN_API_KEY=

# Optional video render tuning
DAYTONA_VIDEO_CPUS=2
DAYTONA_VIDEO_MEMORY_GB=4
DAYTONA_VIDEO_DISK_GB=10
VIDEO_OUTPUT_DIR=generated_videos
VIDEO_RENDER_WORKERS=1

# Browser origins allowed to call the FastAPI service directly
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app

# Hugging Face (for sarvam-m model download, get from https://huggingface.co/settings/tokens)
HF_TOKEN=

# Colab CLI (set after first `colab new` auth flow)
# COLAB_AUTH=oauth2
